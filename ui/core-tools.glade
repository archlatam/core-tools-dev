<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk+" version="3.20"/>

  <object class="GtkApplicationWindow" id="main_window">
    <property name="title">Core Tools</property>
    <property name="default-width">800</property>
    <property name="default-height">450</property>

    <child>
      <object class="GtkBox" id="main_box">
        <property name="orientation">vertical</property>
        <property name="spacing">15</property>
        <property name="margin-top">20</property>
        <property name="margin-bottom">20</property>
        <property name="margin-start">20</property>
        <property name="margin-end">20</property>

        <!-- TITLE -->
        <child>
          <object class="GtkLabel" id="title_label">
            <property name="label">Welcome to Core Linux!</property>
            <property name="halign">start</property>
          </object>
        </child>

        <!-- SUBTITLE -->
        <child>
          <object class="GtkLabel" id="subtitle_label">
            <property name="label">Thank you for joining us!</property>
            <property name="halign">start</property>
            <property name="wrap">true</property>
            <property name="max-width-chars">60</property>
          </object>
        </child>

        <!-- SEPARATOR -->
        <child>
          <object class="GtkSeparator"/>
        </child>
        
        <!-- BUTTON GRID -->
<child>
  <object class="GtkGrid">
    <property name="column-spacing">40</property>
    <property name="row-spacing">15</property>
    <property name="halign">center</property>

    <!-- Columna izquierda -->
    <child>
      <object class="GtkButton" id="update_button">
        <property name="label">Actualizar sistema</property>
        <property name="width-request">200</property>
      </object>
      <packing>
        <property name="left-attach">0</property>
        <property name="top-attach">0</property>
      </packing>
    </child>

    <child>
      <object class="GtkButton" id="clean_cache_button">
        <property name="label">Limpiar caché</property>
        <property name="width-request">200</property>
      </object>
      <packing>
        <property name="left-attach">0</property>
        <property name="top-attach">1</property>
      </packing>
    </child>

    <!-- Columna derecha -->
    <child>
      <object class="GtkButton" id="remove_orphans_button">
        <property name="label">Eliminar paquetes huérfanos</property>
        <property name="width-request">200</property>
      </object>
      <packing>
        <property name="left-attach">1</property>
        <property name="top-attach">0</property>
      </packing>
    </child>

    <child>
      <object class="GtkButton" id="rate_mirrors_button">
        <property name="label">Evaluar mirrors</property>
        <property name="width-request">200</property>
      </object>
      <packing>
        <property name="left-attach">1</property>
        <property name="top-attach">1</property>
      </packing>
    </child>

  </object>
</child>


        <!-- SPACER -->
        <child>
          <object class="GtkBox">
            <property name="vexpand">True</property>
          </object>
        </child>

        <!-- BOTTOM BAR -->
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="halign">start</property>

            <child>
              <object class="GtkComboBoxText" id="languages">
                <property name="width-request">120</property>
                <property name="hexpand">False</property>
                <items>
                  <item id="en">English</item>
                  <item id="es">Español</item>
                </items>
              </object>
            </child>

          </object>
        </child>

      </object>
    </child>
  </object>
</interface>
